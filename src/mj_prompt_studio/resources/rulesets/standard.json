    },
    {
      "name": "style_reference",
      "display_name": "Style Reference",
      "enabled": true,
      "description": "表現や質感の参考。"
    },
    {
      "name": "moodboard",
      "display_name": "Moodboard",
      "enabled": true,
      "description": "複数素材から方向性をまとめる。"
    },
    {
      "name": "personalization_profile",
      "display_name": "Personalization Profile",
      "enabled": true,
      "description": "好みや制作傾向の補助。"
    }
