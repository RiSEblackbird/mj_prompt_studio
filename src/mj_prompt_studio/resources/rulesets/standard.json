    },
    {
      "name": "experimental",
      "display_name": "Experimental",
      "kind": "integer",
      "flag": "--exp",
      "minimum": 0,
      "maximum": 100,
      "description": "実験性の強さ。"
    },
    {
      "name": "tile",
      "display_name": "Tile",
      "kind": "boolean",
      "flag": "--tile",
      "description": "繰り返しパターン向け。"
    },
    {
      "name": "seed",
      "display_name": "Seed",
      "kind": "integer",
      "flag": "--seed",
      "minimum": 0,
      "maximum": 4294967295,
      "description": "再現性のための固定値。"
    },
    {
      "name": "speed_mode",
      "display_name": "Speed Mode",
      "kind": "enum",
      "flag": "--speed",
