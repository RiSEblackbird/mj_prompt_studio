    },
    {
      "name": "chaos",
      "display_name": "Variety",
      "kind": "integer",
      "flag": "--c",
      "minimum": 0,
      "maximum": 100,
      "description": "多様性の強さ。"
    },
    {
      "name": "weird",
      "display_name": "Weird",
      "kind": "integer",
      "flag": "--weird",
      "minimum": 0,
      "maximum": 3000,
